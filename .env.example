# Database
DATABASE_URL="postgresql://user:password@localhost:5432/replica_pages"

# Session
SESSION_SECRET="change-me-to-a-secure-random-string"

# Google OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add redirect URI: {WEB_URL}/api/v1/auth/google/callback (e.g. http://localhost:5173/api/v1/auth/google/callback)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# URLs (for CORS and redirects)
API_URL="http://localhost:3001"
WEB_URL="http://localhost:5173"

# Dev-only: bypass login on localhost (set to 1 to skip Google OAuth when developing)
# BYPASS_AUTH_LOCALHOST=1

# MHTML Import
ASSET_STORAGE_PATH="./data/assets"
# IMPORT_MAX_CONCURRENT=3
