// Replica Pages - Phase 1 Prisma Schema
// PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id                   String    @id @default(cuid())
  name                 String
  allowedEmailDomains  String[]  @default([])
  globalHeaderScript   String?   // Admin-only global script injected before </head>
  globalFooterScript   String?   // Admin-only global script injected before </body>
  scriptAllowlist      Json?     @default("[]") // [{ domain, pathPrefix? }]
  notFoundRedirectUrl  String?   // Global 404 redirect URL (external)
  createdAt            DateTime  @default(now())

  users      User[]
  invites    Invite[]
  folders    Folder[]
  domains    Domain[]
  pages      Page[]
  forms      Form[]
  submissions Submission[]
  integrations Integration[]
  blockLibraryFolders BlockLibraryFolder[]
  importJobs ImportJob[]

  @@index([id])
}

model User {
  id          String   @id @default(cuid())
  workspaceId String
  email       String
  role        String   // Admin | Editor | Viewer
  googleId    String?  @unique
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@index([googleId])
}

model Invite {
  id          String   @id @default(cuid())
  workspaceId String
  email       String
  role        String
  token       String   @unique
  expiresAt   DateTime

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([token])
}

model Folder {
  id          String   @id @default(cuid())
  workspaceId String
  parentId    String?
  name        String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pages     Page[]
  parent    Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Folder[] @relation("FolderHierarchy")

  @@index([workspaceId])
  @@index([parentId])
}

model Domain {
  id                    String    @id @default(cuid())
  workspaceId           String
  hostname              String
  status                String    // Draft | PendingDNS | Verifying | Active | Error
  verificationTxt       String?
  verificationCheckedAt DateTime?
  verificationError     String?   // Error details when status = Error
  cnameTarget           String?
  sslStatus             String?
  embedPolicy           String?   // allow | deny
  custom404PageId       String?   // page to show for 404s
  redirects              Json?     @default("[]") // [{ from, to, status: 301|302 }]
  createdAt             DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, hostname])
  @@index([workspaceId])
}

model Page {
  id                     String   @id @default(cuid())
  workspaceId            String
  folderId               String?
  name                   String
  slug                   String
  contentJson            Json     @default("{}")
  lastPublishedContentJson Json?  @default("{}")
  scripts                Json?    @default("{}")
  publishConfig          Json?    @default("{}")
  scheduleConfig         Json?    @default("{}")
  version                Int      @default(1)
  createdAt              DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folder    Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  formBindings PageFormBinding[]
  submissions Submission[]
  stylesheets PageStylesheet[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([folderId])
}

model Form {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  schemaJson  Json     @default("{}")
  version     Int      @default(1)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pageBindings PageFormBinding[]

  @@index([workspaceId])
}

model PageFormBinding {
  id            String   @id @default(cuid())
  pageId        String
  formId        String?  // optional for hooked forms (no Form record)
  blockId       String?  // for native: block id in contentJson
  type          String   // native | hooked
  selector      String?  // for hooked: CSS selector
  fieldMappings Json?    @default("{}") // { canonicalField: formFieldName }

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  form Form? @relation(fields: [formId], references: [id], onDelete: SetNull)

  @@index([pageId])
  @@index([formId])
}

model Submission {
  id               String    @id @default(cuid())
  workspaceId      String
  pageId           String
  payloadJson      Json      @default("{}")
  deliveryStatus   String?   // pending | delivered | failed
  deliveryAttempts Json?     @default("[]") // [{ attempt, status, error?, at }]
  deliveredAt      DateTime?
  createdAt        DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  page      Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([pageId])
  @@index([createdAt])
  @@index([workspaceId, createdAt])
}

model Integration {
  id              String    @id @default(cuid())
  workspaceId     String
  type            String    // zapier | salesforce | webflow
  configEncrypted String?
  createdAt       DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// Block library: elements and blocks extracted from uploaded pages, foldered by source page
model BlockLibraryFolder {
  id          String   @id @default(cuid())
  workspaceId String
  name        String   // Source page name (e.g. "My Landing Page")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items      BlockLibraryItem[]

  @@index([workspaceId])
}

model BlockLibraryItem {
  id        String   @id @default(cuid())
  folderId  String
  name      String   // Display name (block type or truncated content)
  type      String   // element | block (element = leaf, block = has children)
  blockJson Json     // The block data (id, type, props, children)
  createdAt DateTime @default(now())

  folder BlockLibraryFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([folderId])
}

// MHTML Import Pipeline Models

model ImportJob {
  id              String    @id @default(cuid())
  workspaceId     String
  userId          String
  status          String    @default("queued") // queued | unpacking | rendering | analyzing | building | validating | creating_page | fidelity_check | complete | failed
  stage           String?   // Current processing stage detail
  inputHash       String    // SHA-256 of raw upload bytes
  idempotencyKey  String    @unique // {workspaceId}:{inputHash}
  resultPageId    String?   // Set on successful completion
  errorCode       String?   // Structured error code (e.g. IMPORT_MHTML_MALFORMED)
  errorMessage    String?   // Human-readable error
  statsJson       Json?     // { tiers, sections, assets, warnings }
  timingsJson     Json?     // { unpack, render, analyze, build, validate } in ms
  uploadSizeBytes Int
  sourceRetained  Boolean   @default(false)
  sourceExpiresAt DateTime?
  schemaVersion   Int       @default(1)
  heartbeatAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([idempotencyKey])
}

model PageStylesheet {
  id           String   @id @default(cuid())
  pageId       String
  fragmentId   String   @unique // Unique identifier for this CSS fragment
  scopeId      String   // Matches data-import-scope attribute on block wrapper
  ownerBlockId String   // Block that owns this stylesheet fragment
  cssText      String   // Scoped CSS text (selectors already prefixed)
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([ownerBlockId])
}

model AssetUsage {
  id          String   @id @default(cuid())
  assetId     String   // SHA-256 hash of asset content
  workspaceId String
  pageId      String?
  blockId     String?
  jobId       String?
  createdAt   DateTime @default(now())

  @@index([workspaceId, assetId])
  @@index([pageId])
}

model AuditEvent {
  id          String   @id @default(cuid())
  workspaceId String
  actorId     String
  eventType   String   // import.requested | import.started | import.failed | import.complete | etc.
  jobId       String?
  pageId      String?
  metadata    Json?    // Additional context
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([jobId])
}
